# Environment variables for AI backend (Railway)
# Database points to Supabase

GROQ_API_KEY=your-groq-api-key
TAVILY_API_KEY=your-tavily-api-key

# Supabase connection
DATABASE_SERVER=aws-0-xx.pooler.supabase.com
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER_NAME=postgres.xxxxxxxxxxxx
DATABASE_PASS=your-database-password
DATABASE_SSL=true

# Full HTTPS URLs (required in production)
API_URL=https://your-node-backend.vercel.app/api/v1
AI_BACKEND_URL=https://your-ai-backend.up.railway.app
