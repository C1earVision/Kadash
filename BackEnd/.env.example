# Environment variables for Vercel Node backend deployment
# Copy values from your Supabase project: Settings → Database

JWT_SECRET=your-jwt-secret-here
JWT_LIFETIME=30d

# Supabase connection (use the "Session pooler" host for serverless)
DATABASE_SERVER=aws-0-xx.pooler.supabase.com
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER_NAME=postgres.xxxxxxxxxxxx
DATABASE_PASS=your-database-password
DATABASE_SSL=true
SKIP_CREATE_DATABASE=true
